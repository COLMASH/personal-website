{
  "name": "personal-website",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:api": "cd apps/api && npm run dev",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:api": "cd apps/api && npm test",
    "prepare": "husky",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up --build",
    "db:migrate": "cd apps/api && npx prisma migrate deploy",
    "db:revision": "cd apps/api && npx prisma migrate dev --name"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "turbo": "^2.3.0"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --no-warn-ignored"
    ],
    "apps/web/**/*.{css,json,md}": [
      "prettier --write"
    ],
    "apps/api/**/*.{ts,js}": [
      "prettier --write",
      "eslint --fix --no-warn-ignored"
    ]
  }
}
