# ===========================================
# Production Environment — personal-website
# Deploy to VPS at /opt/personal-website/.env.production
# ===========================================

# ---------- Database ----------
DATABASE_URL=file:/app/data/personal-website.db

# ---------- Auth ----------
JWT_SECRET=         # generate: openssl rand -base64 64
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ---------- App ----------
ENVIRONMENT=production
APP_DEBUG=false
LOG_LEVEL=INFO

# ---------- CORS ----------
CORS_ORIGINS=https://santanaai.com

# ---------- Rate Limiting ----------
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_PERIOD=60

# ---------- Sentry ----------
SENTRY_DSN=         # from sentry.io project settings
SENTRY_ENABLED=true

# ---------- Redis ----------
REDIS_URL=redis://:PASSWORD@redis:6379/0
REDIS_PASSWORD=     # generate: openssl rand -base64 32
