# ===========================================
# Production Environment — personal-website
# Deploy to VPS at /opt/personal-website/.env.production
# ===========================================

# ---------- Database ----------
POSTGRES_DB=personal_website_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=  # generate: openssl rand -base64 32
DATABASE_URL=postgresql://app_user:PASSWORD@db:5432/personal_website_db

# ---------- Auth ----------
JWT_SECRET=         # generate: openssl rand -base64 64
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ---------- App ----------
ENVIRONMENT=production
APP_DEBUG=false
LOG_LEVEL=INFO

# ---------- CORS ----------
BACKEND_CORS_ORIGINS=["https://personal-website.vercel.app"]

# ---------- Rate Limiting ----------
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_PERIOD=60

# ---------- Sentry ----------
SENTRY_DSN=         # from sentry.io project settings
SENTRY_ENABLED=true

# ---------- Redis ----------
REDIS_URL=redis://:PASSWORD@redis:6379/0
REDIS_PASSWORD=     # generate: openssl rand -base64 32
